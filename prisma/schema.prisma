generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Agency {
  id            String      @id @default(cuid())
  agencyName    String
  contactPerson String
  email         String      @unique
  phone         String
  password      String
  gstNumber     String
  address       String
  city          String
  state         String
  role          String      @default("agency")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  quotation     Quotation?
  workers       Worker[]
}

model Admin {
  id        String   @id @default(cuid())
  fullName  String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Quotation {
  id                  String               @id @default(cuid())
  agencyId            String               @unique
  originalFileName    String
  uploadedFilePath    String
  extractionStatus    String               @default("pending")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  agency              Agency               @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  StructuredQuotation StructuredQuotation?
}

model StructuredQuotation {
  id                   String    @id
  structuredData       Json
  vendorCompany        String?
  eventName            String?
  grandTotal           Int?
  createdAt            DateTime  @default(now())
  quotationId          String    @unique
  extractionConfidence Float?
  sourceFileName       String?
  totalManpower        Int?
  totalServices        Int?
  Quotation            Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model Worker {
  id              String   @id @default(cuid())
  name            String
  aadharNumber    String
  dob             String?
  gender          String?
  agencyId        String
  serviceId       String
  department      String   @default("SECURITY")
  role            String   @default("Security Guards")
  ratePerDay      Int      @default(300)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agency          Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  allocations     Allocation[]
}

model Allocation {
  id        String   @id @default(cuid())
  date      String
  zone      String
  slotKey   String
  workerId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([date, zone, slotKey])
}

model Requirement {
  id         String   @id @default(cuid())
  date       String
  zone       String
  department String
  slots      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([date, zone, department])
}

